---
import { SITE, NAV } from '../data/site';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-wordmark">{SITE.name}</div>
        <div class="footer-sub">Full-Stack Developer · GTA, Canada</div>
      </div>
      <div class="footer-cols">
        <div>
          <div class="footer-col-title">Site</div>
          <ul class="footer-col-list">
            {NAV.map((n) => <li><a href={'#' + n.id}>{n.label}</a></li>)}
          </ul>
        </div>
        <div>
          <div class="footer-col-title">Elsewhere</div>
          <ul class="footer-col-list">
            <li><a href={'https://' + SITE.github} target="_blank" rel="noopener">GitHub</a></li>
            <li><a href={'https://' + SITE.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href={'mailto:' + SITE.email}>Email</a></li>
            <li><a href="/resume.pdf" target="_blank" rel="noopener">Resume.pdf</a></li>
          </ul>
        </div>
        <div>
          <div class="footer-col-title">Powered by</div>
          <ul class="footer-col-list">
            <li><a href="https://astro.build" target="_blank" rel="noopener">Astro</a></li>
            <li><a href="https://digitalocean.com" target="_blank" rel="noopener">DigitalOcean</a></li>
            <li><a href="https://nodejs.org" target="_blank" rel="noopener">Node.js</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bot">
      <span>© 2026 {SITE.name} — all rights reserved</span>
      <span class="muted-3">
        <span class="dot dot-sm"></span>
        Designed with Claude Design
      </span>
    </div>
  </div>
</footer>
