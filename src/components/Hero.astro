---
---

<section class="hero" id="top">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-lede">
        <div class="hero-headline">
          <h1>
            <span>Casey Hsu's <span class="em">Portfolio</span><span class="caret"></span></span>
            <span class="muted">full-stack developer<span class="dim"> · storefronts, themes &amp; migrations.</span></span>
          </h1>
        </div>
        <p>
          Three years scoping, building, and shipping production work end-to-end across
          <span class="mono-em mono">Shopify</span>, <span class="mono-em mono">HubSpot</span>, and <span class="mono-em mono">WordPress</span>
          — sole developer on every engagement, from first commit to live site.
        </p>

        <div class="hero-cta">
          <a href="#work" class="btn primary">
            <span>See the work</span><span class="k">→</span>
          </a>
          <a href="/resume.pdf" class="btn">
            <span>Resume.pdf</span><span class="k">↓</span>
          </a>
          <a href="#contact" class="btn">
            <span>Hire me</span><span class="k">⌘K</span>
          </a>
        </div>

        <div class="shell">
          <div class="shell-chrome">
            <span class="shell-dots"><span></span><span></span><span></span></span>
            <span class="shell-title">casey@arch:~ — bash</span>
            <span class="shell-meta">80×24</span>
          </div>
          <div class="shell-body">
            <div class="shell-line"><span class="shell-prompt">~$</span> <span class="shell-cmd">whoami</span></div>
            <div class="shell-out">casey&nbsp;<span class="shell-mute">·</span>&nbsp;toronto, on&nbsp;<span class="shell-mute">·</span>&nbsp;<span class="shell-mute">utc-04</span></div>

            <div class="shell-line"><span class="shell-prompt">~$</span> <span class="shell-cmd">status</span> <span class="shell-flag">--availability</span></div>
            <div class="shell-out"><span class="dot dot-sm"></span>&nbsp;available · full-time + contract</div>

            <div class="shell-line"><span class="shell-prompt">~$</span> <span class="shell-cmd">stack</span> <span class="shell-flag">--primary</span></div>
            <div class="shell-out shell-stack">shopify <span class="shell-mute">·</span> hubspot <span class="shell-mute">·</span> wordpress <span class="shell-mute">·</span> ts</div>

            <div class="shell-line"><span class="shell-prompt">~$</span> <span class="caret"></span></div>
          </div>
        </div>
      </div>

      <div class="hero-photo">
        <div class="hero-photo-chrome">
          <div class="hero-photo-dots"><span></span><span></span><span></span></div>
          <span>~/portrait.jpg</span>
          <span>1280×1600</span>
        </div>
        <div class="hero-photo-body">
          <img class="photo hero-photo-img" src="/casey-hero.jpg" alt="Casey Hsu" width="1080" height="720" fetchpriority="high" decoding="async" />
          <div class="photo-overlay-grad"></div>
          <div class="photo-meta">
            <div class="photo-meta-row mono"><span class="k">NAME</span><span>Casey Hsu</span></div>
            <div class="photo-meta-row mono"><span class="k">ROLE</span><span>Full-Stack JS Developer</span></div>
            <div class="photo-meta-row mono"><span class="k">SINCE</span><span>2023</span></div>
          </div>
        </div>
        <div class="hero-photo-foot">
          <span><span class="dot dot-sm"></span>Updated</span>
          <span class="muted-3">May 2026</span>
        </div>
      </div>
    </div>

    <div class="marquee reveal">
      <span class="muted-3">Shipping with</span>
      <span class="sep">·</span><span>Shopify</span>
      <span class="sep">·</span><span>HubSpot</span>
      <span class="sep">·</span><span>Contentful</span>
      <span class="sep">·</span><span>WordPress</span>
      <span class="sep">·</span><span>Next.js</span>
      <span class="sep">·</span><span>Astro</span>
      <span class="sep">·</span><span>Node.js</span>
      <span class="sep">·</span><span>TypeScript</span>
    </div>
  </div>
</section>
