---
import SectionHead from './SectionHead.astro';
---

<section class="hero" id="top">
  <div class="container">
    <SectionHead
      idx="00"
      kicker="// home"
      inlineDescr
      descr="whoami → casey hsu · full-stack JS · 3y client work · 9y kitchens · GTA"
    />

    <div class="hero-headline">
      <h1>
        <span>Storefronts, themes &amp; <span class="em">migrations</span><span class="caret"></span></span>
        <span class="muted">shipped end-to-end<span class="dim">, solo.</span></span>
      </h1>
    </div>

    <div class="hero-grid">
      <div class="hero-lede">
        <p>
          I'm <strong>Casey Hsu</strong> — three years delivering production e-commerce, custom CMS themes, and platform migrations across
          <span class="mono-em mono">Shopify</span>, <span class="mono-em mono">HubSpot</span>, and <span class="mono-em mono">WordPress</span>.
          I scope, build, and ship end-to-end as a sole developer.
        </p>

        <div class="hero-cta">
          <a href="#work" class="btn primary">
            <span>See the work</span><span class="k">→</span>
          </a>
          <a href="/resume.pdf" class="btn">
            <span>Resume.pdf</span><span class="k">↓</span>
          </a>
          <a href="#contact" class="btn">
            <span>Hire me</span><span class="k">⌘K</span>
          </a>
        </div>

        <div class="shell">
          <div class="shell-line"><span class="shell-prompt">~$</span> contact --availability</div>
          <div class="shell-out">
            <span class="dot dot-sm"></span>
            Available for full-time roles &amp; contract work · GTA + remote
          </div>
        </div>
      </div>

      <div class="hero-photo">
        <div class="hero-photo-chrome">
          <div class="hero-photo-dots"><span></span><span></span><span></span></div>
          <span>~/portrait.jpg</span>
          <span>1280×1600</span>
        </div>
        <div class="hero-photo-body">
          <img class="photo hero-photo-img" src="/casey-hero.jpg" alt="Casey Hsu" />
          <div class="photo-overlay-grad"></div>
          <div class="photo-meta">
            <div class="photo-meta-row mono"><span class="k">NAME</span><span>Casey Hsu</span></div>
            <div class="photo-meta-row mono"><span class="k">ROLE</span><span>Full-Stack JS Developer</span></div>
            <div class="photo-meta-row mono"><span class="k">SINCE</span><span>2023</span></div>
          </div>
        </div>
        <div class="hero-photo-foot">
          <span><span class="dot dot-sm"></span>ONLINE</span>
          <span class="muted-3">updated 5m ago</span>
        </div>
      </div>
    </div>

    <div class="marquee reveal">
      <span class="muted-3">Shipping with</span>
      <span class="sep">·</span><span>Shopify</span>
      <span class="sep">·</span><span>HubSpot</span>
      <span class="sep">·</span><span>Contentful</span>
      <span class="sep">·</span><span>WordPress</span>
      <span class="sep">·</span><span>Next.js</span>
      <span class="sep">·</span><span>Astro</span>
      <span class="sep">·</span><span>Node.js</span>
      <span class="sep">·</span><span>TypeScript</span>
    </div>
  </div>
</section>
