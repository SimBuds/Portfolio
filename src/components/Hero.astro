---
import { Image } from 'astro:assets';
import heroPhoto from '../assets/casey-hero.jpg';
---

<section class="hero" id="top">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-lede">
        <div class="hero-headline">
          <h1>
            <span>Casey Hsu's <span class="em">Portfolio</span></span>
            <span class="muted">cms &amp; e-commerce developer<span class="dim"> · storefronts, themes &amp; migrations.</span></span>
          </h1>
        </div>
        <p>
          Three years scoping, building, and shipping CMS and e-commerce work across
          <span class="mono-em mono">Shopify</span>, <span class="mono-em mono">HubSpot</span>, and <span class="mono-em mono">WordPress</span>,
          with Contentful certification and local-LLM tooling on the side.
        </p>

        <div class="hero-cta">
          <a href="#work" class="btn primary">
            <span>See My Work</span><span class="k">⏎</span>
          </a>
          <a href="/resume.pdf" class="btn">
            <span>My Resume</span><span class="k">⏎</span>
          </a>
          <a href="#contact" class="btn">
            <span>Contact Me</span><span class="k">⏎</span>
          </a>
        </div>
      </div>

      <div class="hero-photo">
        <div class="hero-photo-body">
          <Image
            class="photo hero-photo-img"
            src={heroPhoto}
            alt="Casey Hsu, CMS & e-commerce developer"
            width={1080}
            height={720}
            loading="eager"
            fetchpriority="high"
          />
          <div class="photo-overlay-grad"></div>
          <div class="photo-meta">
            <div class="photo-meta-row mono"><span class="k">NAME</span><span>Casey Hsu</span></div>
            <div class="photo-meta-row mono"><span class="k">ROLE</span><span>CMS &amp; E-commerce Dev</span></div>
            <div class="photo-meta-row mono"><span class="k">SINCE</span><span>2023</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
