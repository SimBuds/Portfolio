---
import { SITE } from '../data/site';
import SectionHead from './SectionHead.astro';

const lines = [
  { icon: '✦',  label: 'EMAIL',    value: SITE.email,    href: 'mailto:' + SITE.email },
  { icon: 'GH', label: 'GITHUB',   value: SITE.github,   href: 'https://' + SITE.github },
  { icon: 'in', label: 'LINKEDIN', value: SITE.linkedin, href: 'https://' + SITE.linkedin }
];
---

<section class="section" id="contact">
  <div class="container">
    <SectionHead
      idx="05"
      kicker="contact"
      inlineDescr
      descr="Available now"/>

    <div class="contact-grid">
      <div class="left reveal">
        <h2>Let's build something <span class="em">worth shipping</span>.</h2>
        <p>Send over the role, project, or platform problem you are trying to solve. I am open to CMS, e-commerce, frontend, and full-stack work across Canada.</p>

        <div class="contact-summary">
          <div>
            <span class="k">Best fit</span>
            <span>Shopify, HubSpot, WordPress, migrations, QA, launches</span>
          </div>
          <div>
            <span class="k">Reply window</span>
            <span>Usually within one business day</span>
          </div>
        </div>

        <div class="contact-lines">
          {lines.map((l) => (
            <a class="contact-line" href={l.href}>
              <span class="icon mono">{l.icon}</span>
              <span class="k">{l.label}</span>
              <span class="v">{l.value}</span>
              <span class="arrow">↗</span>
            </a>
          ))}
        </div>
      </div>

      <form class="contact-form reveal" id="contact-form" action="https://formspree.io/f/maqdrbly" method="POST">
        <div class="contact-form-chrome">
          <span><span class="dot dot-sm"></span>New message</span>
          <span class="muted-3">Secure Formspree relay</span>
        </div>
        <div class="contact-form-body">
          <label for="cf-from">Email</label>
          <input id="cf-from" name="email" class="mono" type="email" placeholder="you@company.com" required />

          <label for="cf-msg">Message</label>
          <textarea id="cf-msg" name="message" placeholder="Tell me what you are building, migrating, hiring for, or trying to fix." required rows="6"></textarea>
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="foot">
            <span class="hint" id="cf-hint">Protected by spam check</span>
            <button type="submit" class="btn primary" id="cf-submit">
              <span>Send message</span><span class="k">→</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('cf-submit');
  const hint = document.getElementById('cf-hint');
  if (form && submit && hint) {
    form.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        form.reset();
        hint.textContent = 'Protected by a hidden spam check';
        submit.innerHTML = '<span>Send message</span><span class="k">→</span>';
        (document.activeElement as HTMLElement | null)?.blur();
      }
    });
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submit.innerHTML = '<span>Sending…</span>';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          submit.innerHTML = '<span>Delivered ✓</span>';
          hint.textContent = 'Delivered - I will reply by email';
          form.reset();
        } else {
          const data = await res.json().catch(() => ({}));
          submit.innerHTML = '<span>Send message</span><span class="k">→</span>';
          hint.textContent = data?.errors?.[0]?.message || 'Send failed - try the email link';
        }
      } catch {
        submit.innerHTML = '<span>Send message</span><span class="k">→</span>';
        hint.textContent = 'Network error - try the email link';
      }
    });
  }
</script>
