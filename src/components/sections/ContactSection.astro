---
import '../../assets/styles/ContactMe.css';
---

<div class="contact-page">
  <div class="contact-layout">
    <div class="contact-info">
      <h2>Let's work together</h2>
      <p class="contact-intro">
        Have a project in mind, a role to fill, or just want to say hello? I'm always open to new opportunities and interesting conversations.
      </p>
      <p class="contact-response-note">
        I typically respond within 1-2 business days.
      </p>
      <div class="contact-links">
        <a href="https://github.com/casey-hsu" target="_blank" rel="noopener noreferrer" class="contact-link">
          <i class="fab fa-github" aria-hidden="true"></i>
          <span>github.com/casey-hsu</span>
        </a>
        <a href="https://www.linkedin.com/in/casey-hsu/" target="_blank" rel="noopener noreferrer" class="contact-link">
          <i class="fab fa-linkedin-in" aria-hidden="true"></i>
          <span>linkedin.com/in/casey-hsu</span>
        </a>
        <a href="https://twitter.com/caseyhsuble" target="_blank" rel="noopener noreferrer" class="contact-link">
          <i class="fab fa-twitter" aria-hidden="true"></i>
          <span>twitter.com/caseyhsuble</span>
        </a>
      </div>
    </div>

    <div class="contact-form-wrapper">
      <div id="status-messages"></div>
      <div class="contact-form">
        <form id="contact-form" aria-label="Contact form">
          <div class="form-group">
            <label for="email">Your Email</label>
            <input type="email" id="email" name="email" required aria-required="true" placeholder="email@example.com" aria-describedby="error-email" />
            <span class="error-text" id="error-email"></span>
          </div>
          <div class="form-group">
            <label for="message">Your Message</label>
            <textarea id="message" name="message" required aria-required="true" placeholder="Tell me what's on your mind..." aria-describedby="error-message"></textarea>
            <span class="error-text" id="error-message"></span>
          </div>
          <button type="submit" class="send-button" id="send-button">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="module" is:inline>
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('status-messages');
  const errors = {
    email: document.getElementById('error-email'),
    message: document.getElementById('error-message'),
  };

  function validate(data) {
    const errs = {};
    if (!data.email) {
      errs.email = 'Email is required';
    } else if (!/\S+@\S+\.\S+/.test(data.email)) {
      errs.email = 'Email is invalid';
    }
    if (!data.message) {
      errs.message = 'Message is required';
    } else if (data.message.length < 10) {
      errs.message = 'Message should be at least 10 characters';
    }
    return errs;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = {
      email: form.email.value,
      message: form.message.value,
      name: form.name ? form.name.value : '',
    };
    const errs = validate(data);
    Object.values(errors).forEach((el) => (el.textContent = ''));
    if (Object.keys(errs).length) {
      Object.entries(errs).forEach(([k, v]) => {
        errors[k].textContent = v;
      });
      return;
    }
    statusEl.textContent = 'Sending...';
    try {
      const res = await fetch('https://formspree.io/f/maqdrbly', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        statusEl.textContent = "Thank you for your message! I'll get back to you soon.";
        form.reset();
      } else {
        const errorData = await res.json();
        statusEl.textContent = errorData.message || 'Failed to send message. Please try again later.';
      }
    } catch (err) {
      statusEl.textContent = 'Network error. Please check your internet connection and try again.';
    }
    setTimeout(() => {
      statusEl.textContent = '';
    }, 5000);
  });
</script>
