---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import '../../assets/styles/FeaturedProjects.css';
import project1Image from '../../assets/images/project1.png';
import project2Image from '../../assets/images/project2.png';
import project3Image from '../../assets/images/project3.png';

type Project = {
  name: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  tags: string[];
  link?: string;
  availabilityNote?: string;
};

const projects: Project[] = [
  {
    name: 'Luxury Jewelry Brand — Shopify Ring Builder',
    description: "Migrated a WordPress portfolio into a 14+ page Shopify storefront and built a custom ring builder for stone, band, and size configuration. The site now supports 200+ SKUs and serves 500+ monthly visitors, with ongoing iteration over a 2+ year engagement.",
    image: project1Image,
    imageAlt: 'Shopify ring builder and storefront',
    tags: ['Shopify', 'Liquid', 'Stripe', 'WordPress', 'SEO'],
    availabilityNote: 'Live site available on request.',
  },
  {
    name: 'AI Agency Client — Custom HubSpot Theme',
    description: 'Rebuilt a legacy HubSpot theme into a custom 8-page implementation with reusable HubL modules and CRM-connected forms. The migration improved maintainability and delivered 90+ PageSpeed scores with a 30% load-time improvement.',
    image: project2Image,
    imageAlt: 'HubSpot performance and homepage',
    tags: ['HubSpot', 'HubL', 'Google Tag Manager', 'JavaScript', 'CSS'],
    availabilityNote: 'Live site available on request.',
  },
  {
    name: 'Vintage Gaming Retailer — Shopify Components',
    description: 'Built collection layouts and custom product modules for a vintage gaming storefront. A 400+ item JSON migration standardized catalog data and removed manual formatting bottlenecks while improving discoverability with technical SEO updates.',
    image: project3Image,
    imageAlt: 'Shopify collection and product modules',
    tags: ['Shopify', 'Liquid', 'JSON', 'SEO', 'Security'],
    availabilityNote: 'Live site available on request.',
  },
];
---

<div class="featured-projects-wrapper">
  <div class="project-header" id="projects">
    <h2>CLIENT WORK</h2>
    <p>Production client work — e-commerce storefronts, custom CMS themes, and platform migrations shipped end-to-end.</p>
  </div>
  <div class="featured-projects">
    {projects.map((project) => (
      <article class="project-card">
        <div class="project-image">
          <Image src={project.image} alt={project.imageAlt} />
        </div>
        <div class="project-content">
          <h3>{project.name}</h3>
          <p>{project.description}</p>
          <div class="project-technologies">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="project-link">
              Visit Site
            </a>
          )}
          {project.availabilityNote && <p class="project-note">{project.availabilityNote}</p>}
        </div>
      </article>
    ))}
  </div>
</div>
