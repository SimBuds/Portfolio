---
import '../../assets/styles/FeaturedProjects.css';

type Project = {
  name: string;
  description: string;
  tags: string[];
  link?: string;
};

const projects: Project[] = [
  {
    name: 'Shopify E-Commerce Storefront',
    description: '14+ page Shopify storefront with 200+ product SKUs serving 500+ monthly visitors. Includes a custom interactive product configurator, Liquid templates, and Stripe payment integration. Ongoing as sole developer across 3 project phases.',
    tags: ['Shopify', 'Liquid', 'Stripe', 'WordPress', 'SEO'],
  },
  {
    name: 'HubSpot CMS Theme',
    description: '8-page custom HubSpot theme built from scratch with full CRM integration. Managed the complete legacy-to-custom migration. Achieved 90+ PageSpeed scores and a 30% improvement in page load speed.',
    tags: ['HubSpot', 'HubL', 'Google Tag Manager', 'JavaScript', 'CSS'],
  },
  {
    name: 'Shopify E-Commerce Components',
    description: 'Custom Shopify page layouts and product display modules for a vintage gaming retailer. Managed a 400+ item catalog migration via JSON restructuring, plus technical SEO audits and security hardening.',
    tags: ['Shopify', 'Liquid', 'JSON', 'SEO', 'Security'],
  },
];
---

<div class="featured-projects-wrapper">
  <div class="project-header" id="projects">
    <h2>CLIENT WORK</h2>
    <p>Production client work — e-commerce storefronts, custom CMS themes, and platform migrations shipped end-to-end.</p>
  </div>
  <div class="featured-projects">
    {projects.map((project) => (
      <article class="project-card">
        <div class="project-image">
          <div class="project-image-placeholder">
            <span>Coming Soon</span>
          </div>
        </div>
        <div class="project-content">
          <h3>{project.name}</h3>
          <p>{project.description}</p>
          <div class="project-technologies">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="project-link">
              Visit Site
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</div>
