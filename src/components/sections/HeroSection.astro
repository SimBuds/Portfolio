---
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/hero-image.jpg';
import '../../assets/styles/HeroSection.css';
---

<div class="hero-section container-fluid">
  <div class="hero-text">
    <h1>Web Developer</h1>
    <p class="lead">
      I'm Casey Hsu — I build production websites for real businesses. Currently working with clients
      across WordPress, HubSpot CMS, and Shopify, delivering responsive storefronts, custom themes,
      and platform migrations. Contentful Certified Professional.
    </p>
    <div class="availability">
      <p>
        <i class="fas fa-check-circle" style="color:green" aria-hidden="true"></i> Available for full-time roles and contract work
      </p>
    </div>
    <a href="#work" class="btn btn-outline-light">See My Work</a>
  </div>
  <div class="hero-image">
    <Image src={heroImage} alt="Casey Hsu" />
  </div>
</div>
