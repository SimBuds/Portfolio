---
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/hero-image.jpg';
import '../../assets/styles/HeroSection.css';
---

<div class="hero-section container-fluid">
  <div class="hero-text">
    <h1>Full-Stack JavaScript Developer</h1>
    <p class="lead">
      I'm Casey Hsu — 3+ years delivering production e-commerce storefronts, custom CMS themes, and
      platform migrations across Shopify, HubSpot, and WordPress. I scope, build, and ship projects
      end-to-end as a sole developer, from technical planning through deployment, performance optimization,
      and ongoing maintenance. Contentful Certified Professional.
    </p>
    <div class="availability">
      <p>
        <span class="availability-icon" aria-hidden="true">✓</span> Available for full-time roles and contract work
      </p>
    </div>
  </div>
  <div class="hero-image">
    <Image src={heroImage} alt="Casey Hsu" loading="eager" fetchpriority="high" />
  </div>
  <div class="hero-actions">
    <a href="#projects" class="btn btn-outline-light">See My Work</a>
    <a href="/resume.pdf" download="Casey-Hsu-Web-Developer-2026.pdf" class="btn btn-outline-light">
      Download Resume (PDF)
    </a>
  </div>
</div>
