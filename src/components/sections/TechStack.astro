---
import type { SimpleIcon } from 'simple-icons';
import {
siApple,
siArchlinux,
siDocker,
siGit,
siJavascript,
siLinux,
siMongodb,
siMysql,
siPostgresql,
siPostman,
siPython,
siReact,
siSpringboot,
siWordpress,
siSharp
} from 'simple-icons';
import '../../assets/styles/TechStack.css';

type TechItem = { name: string; color: string; icon: SimpleIcon | null };

const techCategories: Record<string, TechItem[]> = {
  'Programming Languages': [
    { name: 'JavaScript', color: '#F7DF1E', icon: siJavascript },
    { name: 'Python', color: '#3776AB', icon: siPython },
    { name: 'C#', color: '#239120', icon: siSharp }
  ],
  Databases: [
    { name: 'MongoDB', color: '#47A248', icon: siMongodb },
    { name: 'Postgres', color: '#336791', icon: siPostgresql },
    { name: 'MySQL', color: '#4479A1', icon: siMysql }
  ],
  'Operating Systems': [
    { name: 'Linux', color: '#FCC624', icon: siLinux },
    { name: 'Arch Linux', color: '#1793D1', icon: siArchlinux },
    { name: 'Mac', color: '#A2AAAD', icon: siApple }
  ],
  Frameworks: [
    { name: 'React', color: '#61DAFB', icon: siReact },
    { name: 'Spring', color: '#6DB33F', icon: siSpringboot },
    { name: 'WordPress', color: '#21759B', icon: siWordpress }
  ],
  Tools: [
    { name: 'Git', color: '#F05032', icon: siGit },
    { name: 'Docker', color: '#2496ED', icon: siDocker },
    { name: 'Postman', color: '#FF6C37', icon: siPostman }
  ]
};

---

<section class="tech-stack-banner">
  <div class="tech-stack">
    <div class="tech-stack-header">
      <h2>MY TECH STACK</h2>
      <p>
        The tools, languages, and platforms I use to design, build, and ship fast, reliable experiences.
      </p>
      <a href="/projectlist" class="tech-cta-button">
        View projects built with this stack
      </a>
    </div>

    <div class="tech-stack-categories">
      {Object.entries(techCategories).map(([category, items]) => (
        <div class="category">
          <h3>{category}</h3>
          <div class="tech-items">
            {items.map((tech: TechItem) => (
              <div class="tech-item">
                {tech.icon && (
                  <svg
                    class="tech-icon"
                    viewBox="0 0 24 24"
                    role="img"
                    aria-label={`${tech.name} icon`}
                    focusable="false"
                    style={`fill: ${tech.color}`}
                  >
                    <path d={tech.icon.path} />
                  </svg>
                )}
                <p>{tech.name}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
