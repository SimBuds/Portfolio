---
import '../../assets/styles/WhatImUpToNow.css';

const entries = [
  {
    platform: 'Shopify',
    badge: 'Current Client',
    date: '2023 – Present',
    title: 'Luxury Jewelry Brand — Custom E-Commerce Storefront',
    body: [
      `Ongoing Shopify build and maintenance engagement that started as a WordPress migration and evolved into a full storefront with 200+ SKUs, a custom ring builder, and recurring feature releases.`,
    ],
    tags: ['Shopify', 'Liquid', 'Stripe', 'WordPress', 'Elementor', 'SEO', 'Responsive Design'],
  },
  {
    platform: 'HubSpot CMS',
    badge: 'Completed',
    date: '2025',
    title: 'AI Agency Client — Custom HubSpot Theme & Migration',
    body: [
      `Custom 8-page HubSpot rebuild for an AI agency, including full legacy migration, reusable HubL modules, CRM-connected forms, and performance tuning that reached 90+ PageSpeed with a 30% load-time gain.`,
    ],
    tags: ['HubSpot', 'HubL', 'Custom Theme', 'Google Tag Manager', 'JavaScript', 'CSS', 'Migration'],
  },
  {
    platform: 'Shopify',
    badge: 'Completed',
    date: '2023',
    title: 'Vintage Gaming Retailer — Shopify Components',
    body: [
      `Built custom Shopify collection and product modules, then executed a 400+ item JSON catalog migration with technical SEO and security improvements to make updates faster and storefront structure more reliable.`,
    ],
    tags: ['Shopify', 'Liquid', 'JSON', 'Data Migration', 'SEO Audits', 'Security'],
  },
];
---

<div class="now-section-wrapper">
  <div class="now-section-header">
    <h2>What I'm Up To Now</h2>
    <p>
      Since graduating, I've been building production websites for real clients across WordPress,
      HubSpot, and Shopify — here's a closer look at each project and the work involved.
    </p>
  </div>
  <div class="now-entries">
    {entries.map((entry) => (
      <article class="now-entry">
        <div class="now-entry-meta">
          <span class="now-entry-badge">{entry.badge}</span>
          <span class="now-entry-date">{entry.date}</span>
        </div>
        <h3>{entry.title}</h3>
        <div class="now-entry-body">
          {entry.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <div class="now-entry-tags">
          {entry.tags.map((tag) => (
            <span class="now-tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
  <p class="now-more-link">
    Looking for details? <a href="/#projects">See client work highlights below</a>.
  </p>
</div>
