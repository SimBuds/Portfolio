---
import '../../assets/styles/WhatImUpToNow.css';

const entries = [
  {
    badge: 'In progress',
    date: '2026',
    title: 'Local LLMs with Ollama — Tuned For My Workstation',
    body: [
      `Running and benchmarking open models locally with Ollama on a Ryzen 9 5900X, NVIDIA GeForce RTX 3080 (10 GB), and 232 GB DDR4 — balancing VRAM limits, context length, and throughput so inference stays practical for real coding sessions.`,
      `I'm iterating on GPU-friendly model choices, quantization, and runtime settings to get the best fit for this hardware, and wiring the stack into my CLI workflow alongside cloud tools: local models supplement Claude Code and OpenClaw CLI for fast iteration, offline-capable tasks, and workloads where keeping context on-machine makes sense.`,
    ],
    tags: [
      'Ollama',
      'Local LLM',
      'GPU inference',
      'CUDA',
      'Quantization',
      'Developer tooling',
      'Claude Code',
      'OpenClaw CLI',
      'AMD Ryzen',
      'NVIDIA RTX',
    ],
  },
  {
    badge: 'In progress',
    date: '2026',
    title: 'Arch Linux Migration & Self-Hosted Server',
    body: [
      `Transitioning my daily driver and workflow to Arch Linux to deepen hands-on experience with low-level system configuration, package management, and long-term maintainability. In parallel, I'm standing up a self-hosted server environment — hardening access, documenting services, and building repeatable setup patterns I can rely on for experiments and side projects.`,
      `The goal is a stable, observable stack I understand end-to-end: from OS fundamentals through deployment and routine operations, not just application-level work.`,
    ],
    tags: [
      'Arch Linux',
      'Linux administration',
      'Self-hosting',
      'Homelab',
      'Infrastructure',
      'SSH',
      'Systemd',
      'Security hardening',
    ],
  }
];
---

<div class="now-section-wrapper">
  <div class="now-section-header">
    <h2>What I'm Up To Now</h2>
    <p>
      Outside client delivery, I'm investing in Linux fundamentals, self-hosted infrastructure, and
      a local AI stack — here's what I'm actively building and tuning right now.
    </p>
  </div>
  <div class="now-entries">
    {entries.map((entry) => (
      <article class="now-entry">
        <div class="now-entry-meta">
          <span class="now-entry-badge">{entry.badge}</span>
          <span class="now-entry-date">{entry.date}</span>
        </div>
        <h3>{entry.title}</h3>
        <div class="now-entry-body">
          {entry.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <div class="now-entry-tags">
          {entry.tags.map((tag) => (
            <span class="now-tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</div>
