---
import SectionHead from './SectionHead.astro';
import { NOW } from '../data/now';
---

<section class="section" id="now">
  <div class="container">
    <SectionHead
      idx="01"
      kicker="now"
      inlineDescr
      descr="Currently working on"/>

    <div class="big-title">
      <h2>Currently <span class="accent">building.</span></h2>
    </div>

    <div class="now-grid">
      {NOW.map((it) => (
        <article class="card reveal now-card">
          <div class="now-card-head">
            <span class="cmd">{it.cmd}</span>
            <span class="status">
              <span class="dot dot-sm"></span>
              {it.status}
            </span>
          </div>
          <div class="now-card-body">
            <h3 class="now-title">{it.title}</h3>
            <div class="prose"><p>{it.body}</p></div>
            <p class="now-note">{it.note}</p>
            <a class="now-repo" href={it.repo} target="_blank" rel="noopener noreferrer">
              <span class="arrow">→</span> {it.repo.replace('https://', '')}
            </a>
            <div class="now-tags">
              {it.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
