---
import SectionHead from './SectionHead.astro';
import { NOW } from '../data/now';
---

<section class="section" id="now">
  <div class="container">
    <SectionHead
      idx="01"
      kicker="// now"
      inlineDescr
      descr="This is what i'm currently working on"
    />

    <div class="big-title">
      <h2>Currently building.</h2>
    </div>

    <div class="now-grid">
      {NOW.map((it) => (
        <article class="card reveal now-card">
          <div class="now-card-head">
            <span class="cmd">{it.cmd}</span>
            <span class="status">
              <span class="dot dot-sm"></span>
              {it.status} · {it.day}
            </span>
          </div>
          <div class="now-card-body">
            <h3>{it.title}</h3>
            <div class="prose"><p>{it.body}</p></div>
            <p>{it.note}</p>
            <div class="now-tags">
              {it.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .prose { color: var(--fg-2); line-height: 1.6; font-size: 14px; }
  .prose p { color: var(--fg-2) !important; }
</style>
