---
import SectionHead from './SectionHead.astro';
import { NOW } from '../data/now';
---

<section class="section" id="now">
  <div class="container">
    <SectionHead
      idx="01"
      kicker="// now"
      inlineDescr
      descr="This is what i'm currently working on"
    />

    <div class="big-title">
      <h2>Currently building.</h2>
    </div>

    <div class="now-grid">
      {NOW.map((it) => (
        <article class="card reveal now-card">
          <div class="now-card-head">
            <span class="cmd">{it.cmd}</span>
            <span class="status">
              <span class="dot dot-sm"></span>
              {it.status} · {it.day}
            </span>
          </div>
          <div class="now-card-body">
            <h3 class="now-title">{it.title}</h3>
            <div class="prose"><p>{it.body}</p></div>
            <p class="now-note">{it.note}</p>
            <a class="now-repo" href={it.repo} target="_blank" rel="noopener noreferrer">
              <span class="arrow">→</span> {it.repo.replace('https://', '')}
            </a>
            <div class="now-tags">
              {it.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .now-card { height: 100%; display: flex; flex-direction: column; }
  .now-card-body { display: flex; flex-direction: column; gap: 14px; flex: 1; }
  .now-title { margin: 0; }
  .now-note { margin: 0; }
  .now-repo { margin-top: auto !important; }
  .prose { color: var(--fg-2); line-height: 1.6; font-size: 14px; margin: 0; }
  .prose p { color: var(--fg-2) !important; margin: 0; }
  .now-tags { margin: 0; }
  .now-repo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 4px 0 2px;
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 13px;
    color: var(--fg-2);
    text-decoration: none;
    border-bottom: 1px dashed var(--fg-3, var(--fg-2));
    padding-bottom: 1px;
    width: fit-content;
  }
  .now-repo:hover { color: var(--accent, var(--fg-1)); border-bottom-color: var(--accent, var(--fg-1)); }
  .now-repo .arrow { opacity: 0.7; }
</style>
