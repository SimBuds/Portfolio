---
import { Image } from 'astro:assets';
import favicon from '../assets/images/nav-image.jpg';
import '../assets/styles/Header.css';
---

<nav class="navbar">
  <div class="navbar-inner">
    <div class="navbar-brand">
      <a href="/">
        <Image src={favicon} class="d-inline-block align-top" alt="Casey Hsu's Logo" loading="eager" />
        <span class="brand-text">Casey Hsu</span>
      </a>
    </div>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation" />
    <label class="navbar-toggler" for="nav-toggle" aria-label="Toggle navigation menu">
      <span aria-hidden="true">☰</span>
    </label>
    <div class="navbar-collapse">
      <ul class="navbar-center">
        <li><a href="/#hero-top" class="nav-link">Home</a></li>
        <li><a href="/#projects" class="nav-link">Projects</a></li>
        <li><a href="/#aboutme" class="nav-link">About</a></li>
        <li><a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="nav-link">Resume PDF</a></li>
        <li><a href="/#contact" class="nav-link">Contact</a></li>
      </ul>
      <ul class="navbar-social">
        <li>
          <a href="https://github.com/casey-hsu" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">
            <span class="social-icon" aria-hidden="true">GH</span>
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/casey-hsu/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">
            <span class="social-icon" aria-hidden="true">in</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  const navToggle = document.getElementById('nav-toggle');
  const collapsibleLinks = document.querySelectorAll('.navbar-collapse a');

  collapsibleLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (navToggle instanceof HTMLInputElement) {
        navToggle.checked = false;
      }
    });
  });
</script>
