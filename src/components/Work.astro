---
import SectionHead from './SectionHead.astro';
import { Image } from 'astro:assets';
import { WORK } from '../data/work';
import workJewelry from '../assets/work-jewelry.jpg';
import workTcg from '../assets/work-tcg.jpg';
import workHubspot from '../assets/work-hubspot.jpg';

const WORK_IMAGES: Record<string, typeof workJewelry> = {
  jewelry: workJewelry,
  hubspot: workHubspot,
  tcg: workTcg,
};
---

<section class="section" id="work">
  <div class="container">
    <SectionHead
      idx="02"
      kicker="client work"
      inlineDescr
      descr="Production work"/>

    <div class="big-title">
      <h2><span class="accent">Selected</span> client work.</h2>
    </div>

    <div class="work-list">
      {WORK.map((p) => (
        <article class="work-card reveal">
          <div class="work-visual">
            <Image
              class="photo"
              src={WORK_IMAGES[p.slug]}
              alt={p.client}
              width={800}
              height={500}
            />
            <div class="work-anno">
              <div class="top">{p.annotation}</div>
            </div>
          </div>
          <div class="work-text">
            <div class="work-meta">
              <span class="accent">{p.client}</span>
              <span>·</span>
              <span>{p.role}</span>
              <span>·</span>
              <span>{p.dates}</span>
            </div>
            <h3>{p.title}</h3>
            <div class="prose"><p>{p.summary}</p></div>
            <div class="work-tags">
              {p.stack.map((s) => <span class="tag">{s}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
