---
import SectionHead from './SectionHead.astro';
import { WORK } from '../data/work';
---

<section class="section" id="work">
  <div class="container">
    <SectionHead
      idx="02"
      kicker="// client work"
      inlineDescr
      descr="Production work — e-commerce storefronts, CMS themes"
    />

    <div class="big-title">
      <h2><span class="accent">Selected</span> client work.</h2>
    </div>

    <div class="work-list">
      {WORK.map((p) => (
        <article class="work-card reveal">
          <div class="work-visual">
            <img class="photo" src={`/work-${p.slug}.jpg`} alt={p.client} loading="lazy" decoding="async" />
            {p.slug === 'hubspot' && (
              <div class="coming-soon"><span>Coming soon</span></div>
            )}
            <div class="work-anno">
              <div class="top">{p.annotation}</div>
              <div class="mid"><span class="prompt-4">$</span><span>{p.snippet}</span></div>
              <div class="bot"><span class="dot dot-sm"></span>Live site available on request</div>
            </div>
          </div>
          <div class="work-text">
            <div class="work-meta">
              <span class="accent">{p.client}</span>
              <span>·</span>
              <span>{p.role}</span>
            </div>
            <h3>{p.title}</h3>
            <div class="prose"><p>{p.body}</p></div>
            <div class="work-tags">
              {p.stack.map((s) => <span class="tag">{s}</span>)}
            </div>
            <div class="work-foot">
              <span class="muted-3">Live site available on request</span>
              <a href="#contact" class="cta">request access <span class="arrow">→</span></a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .prose { margin-top: 16px; color: var(--fg-2); line-height: 1.6; font-size: 14px; }
  .prose p { color: var(--fg-2) !important; }
  .coming-soon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(11, 12, 14, 0.62);
    backdrop-filter: blur(2px);
    z-index: 2;
  }
  .coming-soon span {
    padding: 8px 16px;
    border: 1px solid var(--line);
    border-radius: var(--rad-lg);
    background: var(--bg-2);
    color: var(--fg);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
