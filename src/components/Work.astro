---
import { getCollection } from 'astro:content';
import SectionHead from './SectionHead.astro';

const items = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<section class="section" id="work">
  <div class="container">
    <SectionHead
      idx="02"
      kicker="// client work"
      inlineDescr
      descr="Production work — e-commerce storefronts, CMS themes, and platform migrations shipped end-to-end."
    />

    <div class="big-title">
      <h2>Selected client work.</h2>
      <p>Three engagements that span the kind of work I take on — from sole-developer storefronts to legacy theme rebuilds and large data migrations.</p>
    </div>

    <div class="work-list">
      {items.map(async (p) => {
        const { Content } = await p.render();
        const slug = p.slug;
        return (
          <article class="work-card reveal">
            <div class="work-visual">
              <img class="photo" src={`/work-${slug}.jpg`} alt={p.data.client} />
              <div class="work-anno">
                <div class="top">{p.data.annotation}</div>
                <div class="mid"><span class="prompt-4">$</span><span>{p.data.snippet}</span></div>
                <div class="bot"><span class="dot dot-sm"></span>Live site available on request</div>
              </div>
            </div>
            <div class="work-text">
              <div class="work-meta">
                <span>{p.data.client}</span>
                <span>·</span>
                <span>{p.data.role}</span>
              </div>
              <h3>{p.data.title}</h3>
              <div class="prose"><Content /></div>
              <div class="work-tags">
                {p.data.stack.map((s) => <span class="tag">{s}</span>)}
              </div>
              <div class="work-foot">
                <span class="muted-3">Live site available on request</span>
                <a href="#contact" class="cta">request access <span class="arrow">→</span></a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .prose { margin-top: 16px; color: var(--fg-2); line-height: 1.6; font-size: 14px; }
  .prose p { color: var(--fg-2) !important; }
</style>
