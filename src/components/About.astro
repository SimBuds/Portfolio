---
import SectionHead from './SectionHead.astro';
import { Image } from 'astro:assets';

const stats = [
  { k: '2+ yrs', v: 'Shipping production code' },
  { k: '30+',    v: 'Custom Shopify pages' },
  { k: '500+',   v: 'SKUs migrated · normalized' },
  { k: '90+',    v: 'Lighthouse · -30% TTI' },
];
---

<section class="section" id="about">
  <div class="container">
    <SectionHead
      idx="03"
      kicker="// about"
      inlineDescr
      descr="3 years in CMS · ships quality"/>

    <div class="about-grid">
      <div class="about-photo reveal">
        <div class="about-photo-img">
          <Image class="photo" src="/casey-about.jpg" alt="Casey Hsu portrait" width={1080} height={1620} />
        </div>
      </div>

      <div class="about-text reveal">
        <h2>Three years building <span class="accent">CMS platforms</span> and <span class="accent">storefronts</span>, shipped end-to-end.</h2>
        <div class="about-para">
          <p>Most of my work is in <strong>CMS</strong> and e-commerce platforms — Contentful, HubSpot, Shopify, and WordPress — with React and Astro frontends.
            The day-to-day is content modeling, custom themes, platform migrations, and CI/CD.</p>
          <p>I'm a <strong>Contentful Certified Professional</strong> and a <strong>George Brown</strong> Computer Programming and Analysis honours grad.
            On the side I build local LLM tooling to speed up my own workflow.</p>
          <p class="muted">Currently open to CMS and frontend roles in the Greater Toronto Area, including contract, hybrid, and on-site opportunities.</p>
        </div>

        <div class="stats-strip">
          {stats.map((s) => (
            <div class="stat">
              <div class="k">{s.k}</div>
              <div class="v">{s.v}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
