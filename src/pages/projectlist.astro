---
import '../assets/styles/ProjectList.css';
import Layout from '../layouts/Layout.astro';

type Project = {
  name: string;
  description: string;
  tags: string[];
  link?: string;
};

const projects: Project[] = [
  {
    name: 'Shopify E-Commerce Storefront',
    description: '14+ page Shopify storefront with 200+ product SKUs serving 500+ monthly visitors. Includes a custom interactive product configurator, Liquid templates, and Stripe payment integration. Ongoing as sole developer across 3 project phases.',
    tags: ['Shopify', 'Liquid', 'Stripe', 'WordPress', 'Elementor', 'SEO'],
  },
  {
    name: 'HubSpot CMS Theme',
    description: '8-page custom HubSpot theme built from scratch with full CRM integration. Managed the complete legacy-to-custom migration including content mapping, page restructuring, and reusable HubL module architecture. Achieved 90+ PageSpeed scores and a 30% improvement in page load speed.',
    tags: ['HubSpot', 'HubL', 'Google Tag Manager', 'JavaScript', 'CSS', 'Migration'],
  },
  {
    name: 'Shopify E-Commerce Components',
    description: 'Custom Shopify page layouts and product display modules for a vintage gaming retailer. Managed a 400+ item catalog migration via JSON restructuring, along with technical SEO audits and security hardening to improve search visibility.',
    tags: ['Shopify', 'Liquid', 'JSON', 'Data Migration', 'SEO', 'Security'],
  },
];
---

<Layout>
  
  <main class="project-list-wrapper">
    <div class="project-list-header">
      <h1>ALL PROJECTS</h1>
      <p>Production client work across Shopify, HubSpot, and WordPress — built, shipped, and maintained end-to-end.</p>
    </div>
    <div class="project-list">
      {projects.map((project) => (
        <article class="project-list-card">
          <div class="project-list-image">
            <div class="project-image-placeholder">
              <span>Coming Soon</span>
            </div>
          </div>
          <div class="project-list-content">
            <h3>{project.name}</h3>
            <p>{project.description}</p>
            <div class="project-list-technologies">
              {project.tags.map(tag => (
                <span class="project-list-tag">{tag}</span>
              ))}
            </div>
            {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="project-list-link">
              Visit Site
            </a>
          )}
          </div>
        </article>
      ))}
    </div>
  </main>

</Layout>
