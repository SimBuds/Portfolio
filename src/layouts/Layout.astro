---
import '../assets/styles/App.css';
import '../assets/styles/theme.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Casey Hsu',
  jobTitle: 'Full-Stack JavaScript Developer',
  url: 'https://caseyhsu.com/',
  sameAs: [
    'https://github.com/casey-hsu',
    'https://www.linkedin.com/in/casey-hsu/'
  ]
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
			/>
		</noscript>
		<meta name="generator" content={Astro.generator} />
		<title>Casey Hsu | Full-Stack JavaScript Developer | Toronto</title>
		<meta name="description" content="Full-stack JavaScript developer in Toronto specializing in Shopify, HubSpot, and Contentful. 3+ years delivering e-commerce storefronts, custom CMS themes, and platform migrations." />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://caseyhsu.com/" />
		<meta property="og:title" content="Casey Hsu | Full-Stack JavaScript Developer | Toronto" />
		<meta property="og:description" content="Full-stack JavaScript developer in Toronto specializing in Shopify, HubSpot, and Contentful. 3+ years delivering e-commerce storefronts, custom CMS themes, and platform migrations." />
		<meta property="og:image" content="https://caseyhsu.com/favicon.ico" />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
	</head>
	<body>
		<Header />
		<div class="container">
			<slot />
		</div>
		<Footer />
	</body>
</html>
