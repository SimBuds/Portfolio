---
import '../assets/styles/App.css';
import '../assets/styles/theme.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Casey Hsu | Full-Stack JavaScript Developer</title>
		<meta name="description" content="Casey Hsu — Full-stack JavaScript developer with 3+ years delivering Shopify storefronts, HubSpot CMS themes, and platform migrations. Contentful Certified Professional. Based in Toronto." />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://caseyhsu.com/" />
		<meta property="og:title" content="Casey Hsu | Full-Stack JavaScript Developer" />
		<meta property="og:description" content="Casey Hsu — Full-stack JavaScript developer with 3+ years delivering Shopify storefronts, HubSpot CMS themes, and platform migrations. Based in Toronto." />
		<meta property="og:image" content="https://caseyhsu.com/og-image.jpg" />
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:creator" content="@caseyhsuble" />
		<meta name="twitter:title" content="Casey Hsu | Full-Stack JavaScript Developer" />
		<meta name="twitter:description" content="Casey Hsu — Full-stack JavaScript developer with 3+ years delivering Shopify storefronts, HubSpot CMS themes, and platform migrations. Based in Toronto." />
		<meta name="twitter:image" content="https://caseyhsu.com/og-image.jpg" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
	</head>
	<body>
		<Header />
		<div class="container">
			<slot />
		</div>
		<Footer />
	</body>
</html>
